{
  "name": "elderflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:down": "docker compose -f backend/docker-compose.yml down",
    "dev:backend": "pnpm --filter @elderflow/backend start:dev",
    "dev:frontend": "pnpm --filter @elderflow/frontend dev",
    "db:migrate": "pnpm --filter @elderflow/backend db:migrate",
    "db:seed:dev": "pnpm --filter @elderflow/backend db:seed:dev",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter @elderflow/backend test",
    "test:backend:e2e": "pnpm --filter @elderflow/backend test:e2e",
    "test:frontend": "pnpm --filter @elderflow/frontend test",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @elderflow/backend build",
    "build:frontend": "pnpm --filter @elderflow/frontend build"
  }
}
